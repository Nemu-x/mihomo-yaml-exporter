SUBSCRIPTION_URL=https://example.com/sub.yaml
LISTEN_ADDR=0.0.0.0:9123

# mihomo = delay test via embedded Mihomo (default, app-like)
# tcp = TCP/TLS reachability only
CHECK_MODE=mihomo
CHECK_INTERVAL=60s
CHECK_TIMEOUT=10s
CHECK_CONCURRENCY=5

# TCP-only options (CHECK_MODE=tcp)
CHECK_RETRIES=2
CHECK_TLS_PORTS=443,8443

MIHOMO_CONTROLLER=http://127.0.0.1:9090
MIHOMO_DELAY_URL=http://www.gstatic.com/generate_204
MIHOMO_BINARY=/usr/local/bin/mihomo
MIHOMO_CONFIG_DIR=/tmp/mihomo
MIHOMO_STARTUP_TIMEOUT=45s
# MIHOMO_SECRET=

# INCLUDE_GROUPS=
EXCLUDE_GROUPS=DIRECT,REJECT,GLOBAL
EXCLUDE_PROXY_REGEX=(?i)(direct|reject|block|ads|virtual|hidden)
